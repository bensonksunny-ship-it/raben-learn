# Copy to `.env.local` for dev. For Firebase Hosting, set these in CI or `.env.production`
# before `npm run build` — Vite embeds `VITE_*` at build time (they are not read from the server at runtime).

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Must match Firebase Console → Functions → region column (your deploy showed us-central1).
VITE_FIREBASE_FUNCTIONS_REGION=us-central1
